    "# Imports\n",
    "import os\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.preprocessing import LabelEncoder, MinMaxScaler\n",
    "from sklearn.metrics import classification_report, confusion_matrix\n",
    "from sklearn.inspection import permutation_importance\n",
    "from imblearn.over_sampling import SMOTE\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras import layers, models, callbacks\n",
    "import shap\n",
    "from lime.lime_tabular import LimeTabularExplainer\n",
    "import eli5\n",
    "from eli5.sklearn import PermutationImportance\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from pdpbox import pdp\n",
    "from tqdm import tqdm\n",
    "print('Libraries loaded')\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Configuration\n",
    "RANDOM_STATE = 42\n",
    "TEST_SIZE = 0.2\n",
    "LSTM_EPOCHS = 10\n",
    "BATCH_SIZE = 32\n",
    "EXPLAINER_BACKGROUND_SIZE = 200\n",
    "EXPLAINER_SAMPLE_SIZE = 200\n",
    "TOP_K_FEATURES = 15\n",
    "# Set to True if you uploaded UNSW / TON IoT CSVs to /content/ and want to run them\n",
    "RUN_UNSW = False\n",
    "RUN_TONIOT = False\n",
    "print('Config set')\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1) Load NSL-KDD\n",
    "def load_nsl_kdd():\n",
    "    train_url = 'https://raw.githubusercontent.com/defcom17/NSL_KDD/master/KDDTrain+.txt'\n",
    "    test_url = 'https://raw.githubusercontent.com/defcom17/NSL_KDD/master/KDDTest+.txt'\n",
    "    col_names = [\n",
    "        'duration','protocol_type','service','flag','src_bytes','dst_bytes','land','wrong_fragment','urgent',\n",
    "        'hot','num_failed_logins','logged_in','num_compromised','root_shell','su_attempted','num_root',\n",
    "        'num_file_creations','num_shells','num_access_files','num_outbound_cmds','is_host_login','is_guest_login',\n",
    "        'count','srv_count','serror_rate','srv_serror_rate','rerror_rate','srv_rerror_rate','same_srv_rate',\n",
    "        'diff_srv_rate','srv_diff_host_rate','dst_host_count','dst_host_srv_count','dst_host_same_srv_rate',\n",
    "        'dst_host_diff_srv_rate','dst_host_same_src_port_rate','dst_host_srv_diff_host_rate','dst_host_serror_rate',\n",
    "        'dst_host_srv_serror_rate','dst_host_rerror_rate','dst_host_srv_rerror_rate','label'\n",
    "    ]\n",
    "    df_train = pd.read_csv(train_url, names=col_names)\n",
    "    df_test = pd.read_csv(test_url, names=col_names)\n",
    "    df = pd.concat([df_train, df_test], ignore_index=True)\n",
    "    return df\n",
    "\n",
    "df = load_nsl_kdd()\n",
    "print('NSL-KDD loaded, shape:', df.shape)\n",
    "df.head()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 2) Preprocess\n",
    "def preprocess_df(df, label_col='label'):\n",
    "    df = df.copy()\n",
    "    df.drop_duplicates(inplace=True)\n",
    "    df.dropna(inplace=True)\n",
    "    df['is_attack'] = df[label_col].apply(lambda x: 0 if str(x).lower() == 'normal' else 1)\n",
    "    y = df['is_attack'].values\n",
    "    df_feat = df.drop(columns=[label_col, 'is_attack'])\n",
    "    cat_cols = df_feat.select_dtypes(include=['object']).columns.tolist()\n",
    "    encoders = {}\n",
    "    for c in cat_cols:\n",
    "        le = LabelEncoder()\n",
    "        df_feat[c] = le.fit_transform(df_feat[c].astype(str))\n",
    "        encoders[c] = le\n",
    "    numeric_cols = df_feat.select_dtypes(include=[np.number]).columns.tolist()\n",
    "    scaler = MinMaxScaler()\n",
    "    df_feat[numeric_cols] = scaler.fit_transform(df_feat[numeric_cols])\n",
    "    X = df_feat.values\n",
    "    return X, y, df_feat.columns.tolist(), encoders, scaler\n",
    "X, y, feat_names, encoders, scaler = preprocess_df(df)\n",
    "print('Features:', len(feat_names))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3) Train/Test split, SMOTE, reshape, build & train LSTM\n",
    "def reshape_for_lstm(X, timesteps=1):\n",
    "    if timesteps == 1:\n",
    "        return X.reshape((X.shape[0], 1, X.shape[1]))\n",
    "    return X.reshape((X.shape[0], 1, X.shape[1]))\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=TEST_SIZE, random_state=RANDOM_STATE, stratify=y)\n",
    "sm = SMOTE(random_state=RANDOM_STATE)\n",
    "X_train_res, y_train_res = sm.fit_resample(X_train, y_train)\n",
    "X_train_seq = reshape_for_lstm(X_train_res)\n",
    "X_test_seq = reshape_for_lstm(X_test)\n",
    "print('Train shape:', X_train_seq.shape, 'Test shape:', X_test_seq.shape)\n",
    "\n",
    "def build_lstm_model(input_shape, units=50, dropout=0.2):\n",
    "    model = models.Sequential()\n",
    "    model.add(layers.Input(shape=input_shape))\n",
    "    model.add(layers.LSTM(units))\n",
    "    model.add(layers.Dropout(dropout))\n",
    "    model.add(layers.Dense(32, activation='relu'))\n",
    "    model.add(layers.Dense(1, activation='sigmoid'))\n",
    "    model.compile(optimizer=tf.keras.optimizers.Adam(learning_rate=0.001), loss='binary_crossentropy', metrics=['accuracy'])\n",
    "    return model\n",
    "model = build_lstm_model((1, X_train_seq.shape[2]))\n",
    "early = callbacks.EarlyStopping(monitor='val_loss', patience=3, restore_best_weights=True)\n",
    "history = model.fit(X_train_seq, y_train_res, validation_split=0.2, epochs=LSTM_EPOCHS, batch_size=BATCH_SIZE, callbacks=[early], verbose=2)\n",
    "\n",
    "# Plot training history\n",
    "plt.figure(figsize=(8,4))\n",
    "plt.plot(history.history['loss'], label='train_loss')\n",
    "plt.plot(history.history['val_loss'], label='val_loss')\n",
    "plt.legend()\n",
    "plt.title('Training Loss')\n",
    "plt.show()\n",
    "\n",
    "y_pred_prob = model.predict(X_test_seq).ravel()\n",
    "y_pred = (y_pred_prob > 0.5).astype(int)\n",
    "print(classification_report(y_test, y_pred))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4) Explainability: SHAP (sampled), sklearn PFI, ELI5, LIME, PDP/ICE (sampled) and compute FCS\n",
    "def normalize_series(arr):\n",
    "    arr = np.array(arr, dtype=float)\n",
    "    mn = np.nanmin(arr)\n",
    "    mx = np.nanmax(arr)\n",
    "    if mx - mn == 0:\n",
    "        return np.zeros_like(arr)\n",
    "    return (arr - mn) / (mx - mn)\n",
    "\n",
    "# SHAP KernelExplainer (may be slow)\n",
    "def compute_shap_mean_abs(model, X_train_seq, X_test_seq):\n",
    "    try:\n",
    "        idx_bg = np.random.choice(X_train_seq.shape[0], size=min(EXPLAINER_BACKGROUND_SIZE, X_train_seq.shape[0]), replace=False)\n",
    "        idx_samp = np.random.choice(X_test_seq.shape[0], size=min(EXPLAINER_SAMPLE_SIZE, X_test_seq.shape[0]), replace=False)\n",
    "        Xb = X_train_seq[idx_bg]\n",
    "        Xs = X_test_seq[idx_samp]\n",
    "        def f(x):\n",
    "            if x.ndim == 3:\n",
    "                preds = model.predict(x, verbose=0).ravel()\n",
    "            else:\n",
    "                preds = model.predict(x.reshape((x.shape[0], 1, x.shape[1])), verbose=0).ravel()\n",
    "            return np.vstack([1-preds, preds]).T\n",
    "        Xb2 = Xb.reshape((Xb.shape[0], Xb.shape[2]))\n",
    "        Xs2 = Xs.reshape((Xs.shape[0], Xs.shape[2]))\n",
    "        explainer = shap.KernelExplainer(f, Xb2[:min(len(Xb2), 50)])\n",
    "        shap_vals = explainer.shap_values(Xs2[:min(len(Xs2), EXPLAINER_SAMPLE_SIZE)], nsamples=100)\n",
    "        shap_arr = np.array(shap_vals[1])\n",
    "        return np.mean(np.abs(shap_arr), axis=0)\n",
    "    except Exception as e:\n",
    "        print('SHAP error, returning zeros:', e)\n",
    "        return np.zeros(X_train_seq.shape[2])\n",
    "\n",
    "shap_mean_abs = compute_shap_mean_abs(model, X_train_seq, X_test_seq)\n",
    "\n",
    "# sklearn permutation importance (PFI)\n",
    "def compute_pfi(model, X_test_seq, y_test, n_repeats=5):\n",
    "    class KerasWrapper:\n",
    "        def __init__(self, m):\n",
    "            self.model = m\n",
    "        def predict(self, X):\n",
    "            if X.ndim == 3:\n",
    "                preds = self.model.predict(X, verbose=0).ravel()\n",
    "            else:\n",
    "                preds = self.model.predict(X.reshape((X.shape[0], 1, X.shape[1])), verbose=0).ravel()\n",
    "            return (preds > 0.5).astype(int)\n",
    "    wrapper = KerasWrapper(model)\n",
    "    if X_test_seq.ndim == 3 and X_test_seq.shape[1] == 1:\n",
    "        Xflat = X_test_seq.reshape((X_test_seq.shape[0], X_test_seq.shape[2]))\n",
    "    else:\n",
    "        Xflat = X_test_seq\n",
    "    res = permutation_importance(wrapper, Xflat, y_test, n_repeats=n_repeats, random_state=RANDOM_STATE, n_jobs=1, scoring='f1')\n",
    "    return res.importances_mean\n",
    "\n",
    "pfi_vals = compute_pfi(model, X_test_seq, y_test)\n",
    "\n",
    "# ELI5 permutation importance (optional)\n",
    "def compute_eli5(model, X_test_seq, y_test):\n",
    "    class KerasWrap:\n",
    "        def __init__(self, model):\n",
    "            self.model = model\n",
    "        def predict(self, X):\n",
    "            if X.ndim == 3:\n",
    "                preds = self.model.predict(X, verbose=0).ravel()\n",
    "            else:\n",
    "                preds = self.model.predict(X.reshape((X.shape[0], 1, X.shape[1])), verbose=0).ravel()\n",
    "            return (preds>0.5).astype(int)\n",
    "        def predict_proba(self, X):\n",
    "            if X.ndim == 3:\n",
    "                preds = self.model.predict(X, verbose=0).ravel()\n",
    "            else:\n",
    "                preds = self.model.predict(X.reshape((X.shape[0], 1, X.shape[1])), verbose=0).ravel()\n",
    "            return np.vstack([1-preds, preds]).T\n",
    "    try:\n",
    "        wrap = KerasWrap(model)\n",
    "        if X_test_seq.ndim == 3 and X_test_seq.shape[1] == 1:\n",
    "            Xflat = X_test_seq.reshape((X_test_seq.shape[0], X_test_seq.shape[2]))\n",
    "        else:\n",
    "            Xflat = X_test_seq\n",
    "        perm = PermutationImportance(wrap, scoring='f1', n_iter=10, random_state=RANDOM_STATE)\n",
    "        perm.fit(Xflat, y_test)\n",
    "        return perm.feature_importances_\n",
    "    except Exception as e:\n",
    "        print('ELI5 error:', e)\n",
    "        return np.zeros(X_test_seq.shape[2])\n",
    "\n",
    "eli5_vals = compute_eli5(model, X_test_seq, y_test)\n",
    "\n",
    "# PDP/ICE for a few top features by PFI\n",
    "def compute_pdp_ice(model, X_seq, feature_index, grid_size=20):\n",
    "    if X_seq.ndim == 3 and X_seq.shape[1] == 1:\n",
    "        Xflat = X_seq.reshape((X_seq.shape[0], X_seq.shape[2]))\n",
    "        reshape_needed = True\n",
    "    else:\n",
    "        Xflat = X_seq\n",
    "        reshape_needed = False\n",
    "    col_vals = Xflat[:, feature_index]\n",
    "    grid = np.linspace(col_vals.min(), col_vals.max(), grid_size)\n",
    "    preds = []\n",
    "    idxs = np.random.choice(Xflat.shape[0], size=min(200, Xflat.shape[0]), replace=False)\n",
    "    for g in grid:\n",
    "        Xtmp = Xflat.copy()\n",
    "        Xtmp[:, feature_index] = g\n",
    "        if reshape_needed:\n",
    "            Xtmp_in = Xtmp.reshape((Xtmp.shape[0], 1, Xtmp.shape[1]))\n",
    "        else:\n",
    "            Xtmp_in = Xtmp\n",
    "        pred = model.predict(Xtmp_in, verbose=0).ravel()\n",
    "        preds.append(pred)\n",
    "    preds = np.stack(preds, axis=1)\n",
    "    pdp_vals = preds.mean(axis=0)\n",
    "    ice_vals = preds[idxs, :]\n",
    "    return grid, pdp_vals, ice_vals\n",
    "\n",
    "pdp_importance = np.zeros(len(feat_names))\n",
    "ice_importance = np.zeros(len(feat_names))\n",
    "top_pfi_idx = np.argsort(pfi_vals)[::-1][:5]\n",
    "for idx in top_pfi_idx:\n",
    "    grid, pdp_vals, ice_vals = compute_pdp_ice(model, X_test_seq, idx, grid_size=20)\n",
    "    pdp_importance[idx] = np.max(pdp_vals) - np.min(pdp_vals)\n",
    "    ice_importance[idx] = np.mean(np.std(ice_vals, axis=1))\n",
    "\n",
    "# LIME aggregated weights\n",
    "def compute_lime_agg(model, X_train_seq, X_test_seq, feat_names, n_instances=20):\n",
    "    agg = np.zeros(len(feat_names))\n",
    "    try:\n",
    "        if X_train_seq.ndim == 3 and X_train_seq.shape[1] == 1:\n",
    "            Xtrain_flat = X_train_seq.reshape((X_train_seq.shape[0], X_train_seq.shape[2]))\n",
    "            Xtest_flat = X_test_seq.reshape((X_test_seq.shape[0], X_test_seq.shape[2]))\n",
    "        else:\n",
    "            Xtrain_flat = X_train_seq\n",
    "            Xtest_flat = X_test_seq\n",
    "        expl = LimeTabularExplainer(Xtrain_flat[:1000], feature_names=feat_names, class_names=['normal','attack'], discretize_continuous=True)\n",
    "        idxs = np.random.choice(Xtest_flat.shape[0], size=min(n_instances, Xtest_flat.shape[0]), replace=False)\n",
    "        for i in idxs:\n",
    "            exp = expl.explain_instance(Xtest_flat[i], lambda x: np.vstack([1-model.predict(x.reshape((x.shape[0],1,x.shape[1])),verbose=0).ravel(), model.predict(x.reshape((x.shape[0],1,x.shape[1])),verbose=0).ravel()]).T, num_features=10)\n",
    "            for fname, weight in exp.as_list():\n",
    "                for j, fn in enumerate(feat_names):\n",
    "                    if fn in fname:\n",
    "                        agg[j] += abs(weight)\n",
    "        agg = agg / max(1, len(idxs))\n",
    "    except Exception as e:\n",
    "        print('LIME error:', e)\n",
    "    return agg\n",
    "\n",
    "lime_agg = compute_lime_agg(model, X_train_seq, X_test_seq, feat_names, n_instances=20)\n",
    "\n",
    "# Aggregate into FCS\n",
    "def compute_fcs(feat_names, shap_vals, pfi_vals, pdp_vals, ice_vals, lime_vals, eli5_vals):\n",
    "    df = pd.DataFrame(index=feat_names)\n",
    "    df['shap'] = normalize_series(shap_vals)\n",
    "    df['pfi'] = normalize_series(pfi_vals)\n",
    "    df['pdp'] = normalize_series(pdp_vals)\n",
    "    df['ice'] = normalize_series(ice_vals)\n",
    "    df['lime'] = normalize_series(lime_vals)\n",
    "    df['eli5'] = normalize_series(eli5_vals)\n",
    "    df.fillna(0, inplace=True)\n",
    "    df['fcs'] = df.mean(axis=1)\n",
    "    return df.sort_values('fcs', ascending=False)\n",
    "\n",
    "fcs_df = compute_fcs(feat_names, shap_mean_abs, pfi_vals, pdp_importance, ice_importance, lime_agg, eli5_vals)\n",
    "fcs_df.head(20)\n"
   ]
  },
  {
   "cell_type": "code",
